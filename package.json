{
  "name": "yuma",
  "version": "2.0.0",
  "description": "Yuma — Desktop Cat v2 (Календарь, Заметки, Напоминания)",
  "main": "main.js",
  "author": {
    "name": "User",
    "email": "user@example.com"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.yuma.desktop",
    "productName": "Yuma",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Yuma Cat",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "runAfterFinish": true
    },
    "files": [
      "**/*",
      "!dist/*",
      "!**/*.map"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.7.3"
  }
}